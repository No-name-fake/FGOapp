# --- FGO Party Manager Environment Variables ---
# このファイルをコピーして .env という名前で作成し、必要な値を設定してください。
# 注意: .env ファイルは GitHub などの公開リポジトリには絶対にアップロードしないでください。

# Flask の秘密鍵 (セッションの暗号化に使用)
# 適当な長いランダムな文字列を設定してください。
SECRET_KEY=yoursecretkeyhere

# データベースファイルのパス (デフォルトは fgo_app.db)
DATABASE_PATH=fgo_app.db

# --- メール設定 (Gmail) ---
# パスワードリセット・お問い合わせ機能で使用します。
# Googleの「アプリパスワード」を使用してください（通常のパスワードは使用不可）。
# 設定しない場合、メール内容はコンソールに出力されます（開発時に便利）。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# お問い合わせメールの宛先アドレス（管理者のメールアドレス）
ADMIN_EMAIL=admin@example.com
